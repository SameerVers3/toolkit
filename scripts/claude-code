#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
CONFIG_DIR="${HOME}/.config/toolkit"
ENV_FILE="${CONFIG_DIR}/.relay-env"
VENV_DIR="${REPO_ROOT}/.venv"
BIN_DIR="${HOME}/.local/bin"
BIN_NAME="tkr-claude-code"
BIN_PATH="${BIN_DIR}/${BIN_NAME}"
RELAY_PID_FILE="${CONFIG_DIR}/.relay.pid"
RELAY_LOG_FILE="${CONFIG_DIR}/.relay.log"

DEFAULT_BASE_URL="http://127.0.0.1:8080"
DEFAULT_MODEL="claude-sonnet-4-6"
DEFAULT_API_KEY=""

info()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m!!\033[0m %s\n' "$*"; }
die()   { printf '\033[1;31merror:\033[0m %s\n' "$*" >&2; exit 1; }

prompt_value() {
  local __var="$1" __label="$2" __default="${3:-}" __input=""
  if [[ -n "$__default" ]]; then
    printf '%s [%s]: ' "$__label" "$__default"
  else
    printf '%s: ' "$__label"
  fi
  IFS= read -r __input || true
  if [[ -z "$__input" ]]; then
    __input="$__default"
  fi
  printf -v "$__var" '%s' "$__input"
}

prompt_secret() {
  local __var="$1" __label="$2" __hint="${3:-}" __input=""
  if [[ -n "$__hint" ]]; then
    printf '%s [%s] (leave blank to keep): ' "$__label" "$__hint"
  else
    printf '%s: ' "$__label"
  fi
  IFS= read -rs __input || true
  printf '\n'
  if [[ -z "$__input" && -n "$__hint" ]]; then
    printf -v "$__var" '%s' ""
  else
    printf -v "$__var" '%s' "$__input"
  fi
}

mask_key() {
  local key="$1"
  local len=${#key}
  if (( len <= 8 )); then
    printf '****'
  else
    printf '%s…%s' "${key:0:4}" "${key: -4}"
  fi
}

detect_user_shell() {
  local parent=""
  if parent="$(ps -o comm= -p "${PPID}" 2>/dev/null)"; then
    parent="${parent##*/}"
    parent="${parent#-}"
  fi
  case "${parent:-}" in
    fish) echo fish; return ;;
    bash|zsh|sh|dash) echo bash; return ;;
  esac
  case "${SHELL:-}" in
    */fish) echo fish ;;
    *)      echo bash ;;
  esac
}

ensure_on_path() {
  mkdir -p "$BIN_DIR"
  chmod +x "$SCRIPT_PATH"

  if [[ -L "$BIN_PATH" || -e "$BIN_PATH" ]]; then
    if [[ "$(readlink -f "$BIN_PATH" 2>/dev/null || true)" != "$SCRIPT_PATH" ]]; then
      ln -sfn "$SCRIPT_PATH" "$BIN_PATH"
      info "Updated symlink: ${BIN_PATH}"
    fi
  else
    ln -sfn "$SCRIPT_PATH" "$BIN_PATH"
    info "Installed command: ${BIN_NAME}"
    info "Run from anywhere: ${BIN_NAME}"
  fi

  case ":${PATH}:" in
    *":${BIN_DIR}:"*) ;;
    *)
      warn "${BIN_DIR} is not on your PATH."
      local shell_kind
      shell_kind="$(detect_user_shell)"
      if [[ "$shell_kind" == fish ]]; then
        warn "Add to ~/.config/fish/config.fish:"
        warn "  fish_add_path ${BIN_DIR}"
      else
        warn "Add to ~/.bashrc (or ~/.zshrc):"
        warn "  export PATH=\"${BIN_DIR}:\$PATH\""
      fi
      ;;
  esac
}

load_saved_env() {
  ANTHROPIC_BASE_URL="$DEFAULT_BASE_URL"
  ANTHROPIC_MODEL="$DEFAULT_MODEL"
  ANTHROPIC_API_KEY="$DEFAULT_API_KEY"

  if [[ ! -f "$ENV_FILE" ]]; then
    return 0
  fi

  local line key value auth_token=""
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line//[[:space:]]/}" ]] && continue
    [[ "$line" == *"="* ]] || continue
    key="${line%%=*}"
    value="${line#*=}"
    if [[ "$value" =~ ^\"(.*)\"$ ]] || [[ "$value" =~ ^\'(.*)\'$ ]]; then
      value="${BASH_REMATCH[1]}"
    fi
    case "$key" in
      ANTHROPIC_BASE_URL) ANTHROPIC_BASE_URL="$value" ;;
      ANTHROPIC_MODEL)    ANTHROPIC_MODEL="$value" ;;
      ANTHROPIC_API_KEY)  ANTHROPIC_API_KEY="$value" ;;
      ANTHROPIC_AUTH_TOKEN) auth_token="$value" ;;
    esac
  done < "$ENV_FILE"

  if [[ -z "${ANTHROPIC_API_KEY}" && -n "$auth_token" ]]; then
    ANTHROPIC_API_KEY="$auth_token"
  fi
}

save_env() {
  mkdir -p "$CONFIG_DIR"
  umask 077
  cat > "$ENV_FILE" <<EOF
ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL}
ANTHROPIC_AUTH_TOKEN=${ANTHROPIC_API_KEY}
ANTHROPIC_MODEL=${ANTHROPIC_MODEL}
EOF
  chmod 600 "$ENV_FILE"
  info "Saved config → ${ENV_FILE}"
}

configure_exports() {
  load_saved_env

  # Migrate old fireworks model ids to a Claude-looking alias (mapped in .env).
  case "${ANTHROPIC_MODEL}" in
    accounts/fireworks/models/kimi-k2p5|accounts/fireworks/models/kimi-k2p6)
      ANTHROPIC_MODEL="$DEFAULT_MODEL"
      ;;
  esac

  info "Claude Code exports (Enter keeps current value)"
  prompt_value ANTHROPIC_BASE_URL "ANTHROPIC_BASE_URL" "${ANTHROPIC_BASE_URL}"
  prompt_value ANTHROPIC_MODEL     "ANTHROPIC_MODEL"     "${ANTHROPIC_MODEL}"

  local existing_key="${ANTHROPIC_API_KEY:-}"
  local new_key=""
  if [[ -n "$existing_key" ]]; then
    prompt_secret new_key "ANTHROPIC_AUTH_TOKEN (Fireworks key)" "$(mask_key "$existing_key")"
    if [[ -n "$new_key" ]]; then
      ANTHROPIC_API_KEY="$new_key"
    fi
  else
    prompt_secret new_key "ANTHROPIC_AUTH_TOKEN (Fireworks key)"
    ANTHROPIC_API_KEY="$new_key"
  fi

  if [[ -z "${ANTHROPIC_BASE_URL}" ]]; then
    die "ANTHROPIC_BASE_URL is required"
  fi
  if [[ -z "${ANTHROPIC_MODEL}" ]]; then
    die "ANTHROPIC_MODEL is required"
  fi
  if [[ -z "${ANTHROPIC_API_KEY}" ]]; then
    die "ANTHROPIC_AUTH_TOKEN is required"
  fi

  save_env
}

ensure_python() {
  if ! command -v python3 >/dev/null 2>&1; then
    die "python3 not found. Install Python 3.11+ and re-run."
  fi
}

ensure_system_pip() {
  if python3 -m pip --version >/dev/null 2>&1; then
    return 0
  fi

  warn "pip is not available for $(command -v python3)."
  local reply=""
  printf 'Install pip now via ensurepip? [Y/n]: '
  IFS= read -r reply || true
  case "${reply:-Y}" in
    n|N|no|NO) die "pip is required. Install it (e.g. python -m ensurepip --upgrade) and re-run." ;;
  esac

  if python3 -m ensurepip --upgrade >/dev/null 2>&1; then
    info "pip installed via ensurepip"
    return 0
  fi

  die "Could not install pip automatically. Install it for your distro, then re-run."
}

venv_is_healthy() {
  [[ -x "${VENV_DIR}/bin/python" ]] || return 1
  "${VENV_DIR}/bin/python" -c "import sys; sys.exit(0)" >/dev/null 2>&1 || return 1
  if [[ -e "${VENV_DIR}/bin/pip" ]]; then
    "${VENV_DIR}/bin/python" -m pip --version >/dev/null 2>&1 || return 1
  fi
  return 0
}

ensure_venv() {
  local shell_kind
  shell_kind="$(detect_user_shell)"
  info "Detected shell: ${shell_kind}"

  if venv_is_healthy; then
    info "Using existing venv: ${VENV_DIR}"
  else
    if [[ -d "$VENV_DIR" ]]; then
      warn "Existing venv looks broken — recreating ${VENV_DIR}"
      rm -rf "$VENV_DIR"
    else
      info "Creating venv: ${VENV_DIR}"
    fi
    python3 -m venv "$VENV_DIR"
  fi

  if [[ "$shell_kind" == fish ]]; then
    info "Activate later with: source ${VENV_DIR}/bin/activate.fish"
  else
    info "Activate later with: source ${VENV_DIR}/bin/activate"
  fi
}

ensure_package() {
  local py="${VENV_DIR}/bin/python"

  if ! "$py" -m pip --version >/dev/null 2>&1; then
    info "Bootstrapping pip inside venv…"
    "$py" -m ensurepip --upgrade
  fi

  if "$py" -c "import relay" >/dev/null 2>&1; then
    info "Relay package already installed"
    return 0
  fi

  info "Installing relay package (pip install -e .)…"
  "$py" -m pip install -e "$REPO_ROOT"
}

relay_health_url() {
  local base="${ANTHROPIC_BASE_URL%/}"
  printf '%s/health' "$base"
}

relay_is_up() {
  local url
  url="$(relay_health_url)"
  curl -fsS --max-time 2 "$url" >/dev/null 2>&1
}

start_relay() {
  if relay_is_up; then
    info "Relay already running at ${ANTHROPIC_BASE_URL}"
    return 0
  fi

  mkdir -p "$CONFIG_DIR"
  local relay_bin="${VENV_DIR}/bin/anthropic-relay"
  [[ -x "$relay_bin" ]] || die "anthropic-relay missing — package install failed"

  info "Starting relay…"
  (
    cd "$REPO_ROOT"
    nohup "$relay_bin" >>"$RELAY_LOG_FILE" 2>&1 &
    echo $! >"$RELAY_PID_FILE"
  )

  local pid attempts=0
  pid="$(cat "$RELAY_PID_FILE" 2>/dev/null || true)"
  while (( attempts < 40 )); do
    if relay_is_up; then
      info "Relay ready (pid ${pid:-?})"
      return 0
    fi
    if [[ -n "$pid" ]] && ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 0.5
    attempts=$((attempts + 1))
  done

  warn "Relay did not become healthy. Last log lines:"
  tail -n 20 "$RELAY_LOG_FILE" 2>/dev/null || true
  die "Failed to start relay — see ${RELAY_LOG_FILE}"
}

launch_claude() {
  if ! command -v claude >/dev/null 2>&1; then
    die "claude CLI not found on PATH. Install Claude Code first."
  fi

  if [[ $# -gt 0 && -d "$1" ]]; then
    local target
    target="$(cd "$1" && pwd)" || die "cannot open directory: $1"
    cd "$target" || die "cannot cd to ${target}"
    info "Working directory: ${target}"
    shift
  fi

  info "Opening Claude Code…"
  export ANTHROPIC_BASE_URL
  export ANTHROPIC_MODEL
  export ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_API_KEY}"
  unset ANTHROPIC_API_KEY

  exec claude "$@"
}

main() {
  ensure_on_path
  ensure_python
  ensure_system_pip
  configure_exports
  ensure_venv
  ensure_package
  start_relay
  launch_claude "$@"
}

main "$@"
